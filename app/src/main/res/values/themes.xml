<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.MindMate" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/mindmate_primary</item>
        <item name="colorSecondary">@color/mindmate_secondary</item>
        <item name="colorTertiary">@color/mindmate_tertiary</item>
        <item name="android:colorBackground">@color/mindmate_background</item>
        <item name="colorSurface">@color/mindmate_surface_container</item>
        <item name="colorSurfaceVariant">@color/mindmate_surface_variant</item>
        <item name="colorPrimaryContainer">@color/mindmate_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/mindmate_on_primary_container</item>
        <item name="colorOutline">@color/mindmate_outline</item>
        <item name="colorOnSurface">@color/mindmate_text_primary</item>
        <item name="colorOnSurfaceVariant">@color/mindmate_text_secondary</item>
        <item name="android:fontFamily">sans</item>
        <item name="materialButtonStyle">@style/Widget.MindMate.Button</item>
        <item name="textInputStyle">@style/Widget.MindMate.TextInputLayout</item>
        <item name="bottomNavigationStyle">@style/Widget.MindMate.BottomNavigation</item>
        <item name="navigationViewStyle">@style/Widget.MindMate.NavigationView</item>
        <item name="materialCardViewStyle">@style/Widget.MindMate.Card</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:windowLayoutInDisplayCutoutMode">never</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:statusBarColor">@color/mindmate_surface_container</item>
        <item name="android:navigationBarColor">@color/mindmate_surface_container</item>
    </style>

    <style name="Theme.MindMate" parent="Base.Theme.MindMate" />

    <style name="Widget.MindMate.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">24dp</item>
        <item name="android:minHeight">@dimen/mindmate_button_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans</item>
        <item name="backgroundTint">@color/mindmate_primary</item>
    </style>

    <style name="Widget.MindMate.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/mindmate_card_radius</item>
        <item name="boxCornerRadiusTopEnd">@dimen/mindmate_card_radius</item>
        <item name="boxCornerRadiusBottomStart">@dimen/mindmate_card_radius</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/mindmate_card_radius</item>
        <item name="boxStrokeColor">@color/mindmate_outline</item>
        <item name="hintTextColor">@color/mindmate_text_secondary</item>
        <item name="boxBackgroundColor">@color/mindmate_surface_container</item>
    </style>

    <style name="Widget.MindMate.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/mindmate_card_radius</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeColor">@color/mindmate_outline</item>
        <item name="strokeWidth">@dimen/mindmate_card_stroke</item>
        <item name="cardBackgroundColor">@color/mindmate_surface_container</item>
    </style>

    <style name="Widget.MindMate.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/mindmate_surface_container</item>
        <item name="elevation">@dimen/mindmate_bottom_nav_elevation</item>
        <item name="itemIconTint">@color/nav_item_color</item>
        <item name="itemTextColor">@color/nav_item_color</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.MindMate.BottomNavigation.ActiveIndicator</item>
    </style>

    <style name="Widget.MindMate.BottomNavigation.ActiveIndicator" parent="">
        <item name="android:color">@color/mindmate_primary_container</item>
    </style>

    <style name="Widget.MindMate.NavigationView" parent="Widget.Material3.NavigationView">
        <item name="android:background">@color/mindmate_surface_container</item>
        <item name="itemIconTint">@color/nav_item_color</item>
        <item name="itemTextColor">@color/nav_item_color</item>
    </style>

    <style name="ShapeAppearance.MindMate.NavItem" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">18dp</item>
    </style>
</resources>
